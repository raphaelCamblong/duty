---
import { getEntry, render } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

const entry = await getEntry('topics', 'tracks');
if (!entry) throw new Error('docs/tracks.md not found');
const { Content, headings } = await render(entry);
---

<StarlightPage
	frontmatter={{
		title: 'Tracks & boards',
		description: 'Tracks are just folders with a board. They nest all the way down, each one self-contained.',
	}}
	headings={headings}
>
	<Content />
</StarlightPage>

<style is:global>
	/* The sourced file carries its own H1; Starlight already renders the title. */
	.sl-markdown-content > h1:first-child {
		display: none;
	}
</style>
