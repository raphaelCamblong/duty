---
import { getEntry, render } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

const entry = await getEntry('topics', 'tui');
if (!entry) throw new Error('docs/tui.md not found');
const { Content, headings } = await render(entry);
---

<StarlightPage
	frontmatter={{
		title: 'TUI',
		description: 'A live, read-only view of your board that re-reads itself the moment a file changes.',
	}}
	headings={headings}
>
	<Content />
</StarlightPage>

<style is:global>
	/* The sourced file carries its own H1; Starlight already renders the title. */
	.sl-markdown-content > h1:first-child {
		display: none;
	}
</style>
