---
import { getEntry, render } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

const entry = await getEntry('convention', 'readme');
if (!entry) throw new Error('duty/README.md not found');
const { Content, headings } = await render(entry);
---

<StarlightPage
	frontmatter={{
		title: 'The task convention',
		description: 'The one-page contract your team and your agents both read — how a task file and its board fit together.',
	}}
	headings={headings}
>
	<Content />
</StarlightPage>

<style is:global>
	/* The sourced file carries its own H1; Starlight already renders the title. */
	.sl-markdown-content > h1:first-child {
		display: none;
	}
</style>
