---
import { getEntry, render } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

const entry = await getEntry('topics', 'tasks');
if (!entry) throw new Error('docs/tasks.md not found');
const { Content, headings } = await render(entry);
---

<StarlightPage
	frontmatter={{
		title: 'Tasks',
		description: 'One task, one Markdown file, sized for a single sitting — and a board that always matches it.',
	}}
	headings={headings}
>
	<Content />
</StarlightPage>

<style is:global>
	/* The sourced file carries its own H1; Starlight already renders the title. */
	.sl-markdown-content > h1:first-child {
		display: none;
	}
</style>
